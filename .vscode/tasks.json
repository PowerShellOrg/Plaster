{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    // Start PowerShell
    "windows": {
        "options": {
            "shell": {
                "executable": "pwsh.exe",
                "args": [
                    "-NoProfile",
                    "-ExecutionPolicy",
                    "Bypass",
                    "-Command"
                ]
            }
        }
    },
    "linux": {
        "options": {
            "shell": {
                "executable": "/usr/bin/pwsh",
                "args": [
                    "-NoProfile",
                    "-Command"
                ]
            }
        }
    },
    "osx": {
        "options": {
            "shell": {
                "executable": "/usr/local/bin/pwsh",
                "args": [
                    "-NoProfile",
                    "-Command"
                ]
            }
        }
    },
    // Associate with test task runner
    "tasks": [
        {
            "label": "Bootstrap",
            "type": "shell",
            "command": "./build.ps1 -Task Init -Bootstrap",
            "problemMatcher": []
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "./build.ps1 -Task Clean",
            "problemMatcher": []
        },
        {
            "label": "Build",
            "type": "shell",
            "command": "./build.ps1 -Task Build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "BuildHelp",
            "type": "shell",
            "command": "./build.ps1 -Task BuildHelp",
            "problemMatcher": []
        },
        {
            "label": "Analyze",
            "type": "shell",
            "command": "./build.ps1 -Task Analyze",
            "problemMatcher": []
        },
        {
            "label": "Install",
            "type": "shell",
            "command": "./build.ps1 -Task Install",
            "problemMatcher": []
        },
        {
            "label": "Publish",
            "type": "shell",
            "command": "./build.ps1 -Task Publish",
            "problemMatcher": []
        },
        {
            "label": "Test",
            "type": "shell",
            "command": "./build.ps1 -Task Test",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": [
                "$pester"
            ]
        }
    ]
}